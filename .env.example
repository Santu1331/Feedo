# ─── Feedo Chatbot env ──────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in your own values.
# `.env.local` is git-ignored so secrets stay out of version control.

# Used by the SERVER (api/chat.js) on Vercel. This is the safe production path.
OPENROUTER_API_KEY=sk-or-v1-...your-rotated-key...
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_REFERER=https://feedozone.app

# ⚠️ DEV-ONLY: used by the BROWSER when `vite dev` is running and the server
# function `/api/chat` is not available. This key WILL be visible in the
# browser bundle when set, so use a low-quota key and DO NOT set this in
# Vercel production. In production the chatbot uses the server proxy above.
VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
