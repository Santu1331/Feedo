rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // VENDORS — anyone logged in can read, only founder/vendor can write
    match /vendors/{vendorId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (request.auth.uid == vendorId ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'founder');
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'founder';

      // Menu subcollection
      match /menu/{itemId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null &&
          (request.auth.uid == vendorId ||
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'founder');
      }
    }

    // USERS — read own profile, founder reads all
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ORDERS — users place, vendors/founder read/update
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'founder';
    }
  }
}
