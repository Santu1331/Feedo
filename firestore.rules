rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ─────────────────────────────────────────────────
    function isFounder() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'founder';
    }

    function isManager() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    function isFounderOrManager() {
      return isFounder() || isManager();
    }

    function isVendor() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor';
    }

    // ── VENDORS ───────────────────────────────────────────────────────────
    match /vendors/{vendorId} {
      allow read: if request.auth != null;

      // Founder OR manager can create vendors
      allow create: if request.auth != null && isFounderOrManager();

      // Vendor can update own doc; founder or manager can update any vendor
      allow update: if request.auth != null &&
        (request.auth.uid == vendorId || isFounderOrManager());

      // Only founder can delete vendors
      allow delete: if isFounder();

      match /menu/{itemId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null &&
          (request.auth.uid == vendorId || isFounderOrManager());
      }

      match /combos/{comboId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null &&
          (request.auth.uid == vendorId || isFounderOrManager());
      }
    }

    // ── MANAGERS ──────────────────────────────────────────────────────────
    match /managers/{managerId} {
      // Manager can read their own doc; founder can read all
      allow read: if request.auth != null &&
        (request.auth.uid == managerId || isFounder());

      // Only founder can create/delete manager accounts
      allow create: if isFounder();
      allow delete: if isFounder();

      // Founder can update any manager; manager can update their own doc (not role)
      allow update: if request.auth != null &&
        (isFounder() ||
         (request.auth.uid == managerId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'city', 'district'])));
    }

    // ── USERS ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        isFounder() ||
        isManager() ||
        isVendor()
      );

      // Users can create their own doc; founder/manager can create vendor/manager docs
      allow create: if request.auth != null && (
        request.auth.uid == userId ||
        isFounder() ||
        isManager()
      );

      // Users can update their own doc (not role); founder can update any; manager can update vendor docs
      allow update: if request.auth != null && (
        (request.auth.uid == userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
        isFounder() ||
        (isManager() &&
         get(/databases/$(database)/documents/users/$(userId)).data.role == 'vendor')
      );

      // Only founder can delete user docs
      allow delete: if isFounder();
    }

    // ── ORDERS ────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow create: if request.auth != null;

      // Customer, vendor, founder, or manager can read/update orders
      allow read, update: if request.auth != null && (
        request.auth.uid == resource.data.userUid ||
        request.auth.uid == resource.data.vendorUid ||
        isFounder() ||
        isManager()
      );

      // Only founder can delete orders
      allow delete: if isFounder();
    }

    // ── NOTIFICATIONS ─────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if request.auth != null &&
        resource.data.toUid == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        resource.data.toUid == request.auth.uid;
      allow delete: if request.auth != null && (
        resource.data.toUid == request.auth.uid ||
        isFounder()
      );
    }

    // ── REVIEWS ───────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isFounder()
      );
    }

    // ── SUPPORT TICKETS ───────────────────────────────────────────────────
    match /supportTickets/{ticketId} {
      allow create: if request.auth != null &&
        request.resource.data.userUid == request.auth.uid;

      // Customer, founder, or manager can read/update tickets
      allow read, update: if request.auth != null && (
        request.auth.uid == resource.data.userUid ||
        isFounder() ||
        isManager()
      );

      allow delete: if isFounder();
    }

    // ── BROADCAST HISTORY ─────────────────────────────────────────────────
    match /broadcastHistory/{broadcastId} {
      allow read, write: if isFounder();
    }

    // ── PUSH HISTORY ──────────────────────────────────────────────────────
    match /pushHistory/{pushId} {
      allow read, write: if isFounder();
    }

    // ── SUBSCRIPTION BILLS ────────────────────────────────────────────────
    match /subscriptionBills/{billId} {
      // Founder can read all; manager and vendor can read their own city/vendor bills
      allow read: if request.auth != null && (
        isFounder() ||
        isManager() ||
        resource.data.vendorId == request.auth.uid
      );
      allow write: if isFounder();
    }

    // ── ACCOUNT DELETIONS ─────────────────────────────────────────────────
    match /accountDeletions/{requestId} {
      allow create: if true;
      allow read, update, delete: if isFounder();
    }
  }
}
